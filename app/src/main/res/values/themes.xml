<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Main App Theme - NO ACTION BAR -->
    <style name="Theme.Trying_native" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Ensures no title bar shows -->
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/app_icon_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/app_icon_foreground</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/app_icon_background</item>
        <item name="postSplashScreenTheme">@style/Theme.Trying_native</item>
    </style>

    <style name="Theme.Trying_native.Fullscreen" parent="Theme.Trying_native">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
    </style>

